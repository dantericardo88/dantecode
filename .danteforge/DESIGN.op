# ============================================================================
# DanteCode VS Code Sidebar — OpenPencil Design Specification
# Generated: 2026-03-15 | Target: VS Code WebviewViewProvider
# ============================================================================
#
# Format: OpenPencil Zone Layout (.op)
# Renderer: VS Code Webview (HTML/CSS/JS, CSP-restricted)
# Theme: VS Code CSS custom properties (light + dark adaptive)
#
# This file defines the spatial layout, component hierarchy, interaction
# patterns, and visual semantics for the DanteCode sidebar experience.
# ============================================================================

@meta
  name: "DanteCode VS Code Sidebar"
  version: "1.0.0"
  target: "vscode-webview"
  viewport: { width: 300, height: 800, scalable: true }
  theme: "vscode-adaptive"
  csp: "default-src 'none'; style-src 'nonce-{nonce}'; script-src 'nonce-{nonce}'"

# ============================================================================
# ACTIVITY BAR
# ============================================================================

@zone activity-bar-icon
  type: icon
  position: { slot: "activityBar" }
  icon: "dante-fire"  # Custom SVG icon registered in package.json
  tooltip: "DanteCode"
  badge:
    condition: "hasUnreadMessages || hasGateFailure"
    style: "dot"

# ============================================================================
# VIEW CONTAINER: dantecodePanel
# ============================================================================
# Contains two collapsible views:
#   1. dantecode.chatView  — Primary chat interface
#   2. dantecode.auditView — Audit event log
# ============================================================================

@container sidebar-panel
  id: "dantecodePanel"
  position: { slot: "sidebar", order: 1 }
  layout: column
  fill: parent

  # ==========================================================================
  # VIEW 1: CHAT SIDEBAR
  # ==========================================================================

  @view chat-view
    id: "dantecode.chatView"
    title: "DanteCode Chat"
    layout: column
    fill: parent
    retain: true  # retainContextWhenHidden

    # ---- Zone: Header Bar ----
    @zone header
      layout: row
      align: center
      justify: space-between
      padding: { x: 12, y: 8 }
      border: { bottom: 1, color: "panel-border" }
      background: "sideBarSectionHeader-background"
      shrink: 0

      @element title
        type: text
        content: "DanteCode Chat"
        style:
          font-weight: 600
          font-size: 13
          color: "sideBarSectionHeader-foreground"

      @element pdse-badge
        type: badge
        visibility: conditional  # shown after first PDSE score
        layout: row
        align: center
        gap: 4
        padding: { x: 8, y: 2 }
        border-radius: 10
        font-size: 11
        font-weight: 600
        variants:
          passed:
            background: "testing-iconPassed"
            color: "#FFFFFF"
          failed:
            background: "testing-iconFailed"
            color: "#FFFFFF"
        content: "PDSE: {score}"

    # ---- Zone: Model Selector ----
    @zone model-bar
      layout: row
      align: center
      gap: 8
      padding: { x: 12, y: 6 }
      border: { bottom: 1, color: "panel-border" }
      background: "sideBar-background"
      shrink: 0

      @element model-label
        type: label
        content: "Model:"
        style:
          font-size: 11
          color: "descriptionForeground"
          white-space: nowrap

      @element model-select
        type: dropdown
        flex: 1
        options:
          - { value: "grok/grok-3", label: "grok-3" }
          - { value: "grok/grok-3-mini", label: "grok-3-mini" }
          - { value: "anthropic/claude-sonnet-4-20250514", label: "claude-sonnet-4" }
          - { value: "anthropic/claude-opus-4-20250514", label: "claude-opus-4" }
          - { value: "openai/gpt-4o", label: "gpt-4o" }
          - { value: "openai/o3-mini", label: "o3-mini" }
          - { value: "google/gemini-2.5-pro", label: "gemini-2.5-pro" }
          - { value: "ollama/llama3", label: "llama3 (local)" }
          - { value: "ollama/codellama", label: "codellama (local)" }
        style:
          padding: { x: 6, y: 3 }
          font-size: 12
          color: "dropdown-foreground"
          background: "dropdown-background"
          border: { width: 1, color: "dropdown-border" }
          border-radius: 2
        on-focus:
          border-color: "focusBorder"
        on-change: "model_change"

    # ---- Zone: Context Files ----
    @zone context-bar
      layout: row
      wrap: true
      gap: 4
      padding: { x: 12, y: 6 }
      border: { bottom: 1, color: "panel-border" }
      shrink: 0
      visibility: "contextFiles.length > 0"  # hidden when empty

      @element context-pill
        type: pill
        repeat: "contextFiles"
        layout: row
        align: center
        gap: 4
        padding: { x: 8, y: 2 }
        max-width: 200
        overflow: ellipsis
        style:
          font-size: 11
          background: "badge-background"
          color: "badge-foreground"
          border-radius: 10

        @element filename
          type: text
          content: "{file.basename}"  # show filename only, not full path

        @element remove-btn
          type: button
          content: "\u00D7"
          cursor: pointer
          opacity: 0.7
          font-size: 12
          on-hover: { opacity: 1 }
          on-click: "file_remove"
          title: "Remove from context"

    # ---- Zone: Messages ----
    @zone messages
      layout: column
      flex: 1
      overflow-y: auto
      padding: 12
      gap: 12

      # Welcome screen (shown when no messages)
      @element welcome
        type: card
        visibility: "messages.length === 0"
        layout: column
        align: center
        justify: center
        padding: { x: 16, y: 32 }
        text-align: center
        gap: 12
        color: "descriptionForeground"

        @element welcome-title
          type: heading
          level: 2
          content: "Welcome to DanteCode"
          style:
            font-size: 16
            font-weight: 600
            color: "foreground"

        @element welcome-desc
          type: text
          content: "Model-agnostic AI coding assistant with DanteForge quality gates."
          style:
            font-size: 12
            line-height: 1.6
            max-width: 280

        @element welcome-hint
          type: text
          content: "Type a message below to start, or use {kbd:Ctrl+Shift+A} to add files to context."
          style:
            font-size: 12
            line-height: 1.6
            max-width: 280

      # Message bubbles (repeated for each message)
      @element message
        type: card
        repeat: "messages"
        layout: column
        gap: 4
        max-width: "100%"

        @element message-header
          type: text
          layout: row
          align: center
          gap: 6
          style:
            font-size: 11
            font-weight: 600
            color: "descriptionForeground"
          variants:
            user:
              color: "textLink-foreground"
              content: "You"
            assistant:
              color: "charts-green"
              content: "DanteCode"

        @element message-body
          type: richtext
          content: "{message.content}"
          style:
            font-size: 13
            line-height: 1.5
            white-space: pre-wrap
            word-wrap: break-word
            padding: { x: 12, y: 8 }
            border-radius: 6
            background: "editor-background"
            border: { width: 1, color: "panel-border" }
          variants:
            user:
              border-left: { width: 3, color: "textLink-foreground" }
            assistant:
              border-left: { width: 3, color: "charts-green" }
            error:
              background: "inputValidation-errorBackground"
              border-left: { width: 3, color: "inputValidation-errorBorder" }
              color: "errorForeground"

        @element code-block
          type: code
          parent: message-body
          style:
            font-family: "editor-font-family"
            font-size: "editor-font-size"
            background: "textCodeBlock-background"
            padding: { x: 4, y: 1 }
            border-radius: 3

        @element pre-block
          type: preformatted
          parent: message-body
          style:
            margin: { y: 8 }
            padding: 8
            background: "textCodeBlock-background"
            border-radius: 4
            overflow-x: auto

    # ---- Zone: Typing Indicator ----
    @zone typing-indicator
      visibility: "isStreaming"
      padding: { x: 12, y: 8 }
      style:
        font-size: 12
        color: "descriptionForeground"
        font-style: italic
      content: "DanteCode is thinking..."

    # ---- Zone: Input Area ----
    @zone input-area
      layout: row
      gap: 6
      padding: { x: 12, y: 8 }
      border: { top: 1, color: "panel-border" }
      background: "sideBar-background"
      shrink: 0

      @element textarea
        type: textarea
        flex: 1
        placeholder: "Ask DanteCode anything..."
        rows: 1
        auto-resize: true
        min-height: 36
        max-height: 120
        style:
          padding: { x: 10, y: 8 }
          font-family: "font-family"
          font-size: 13
          color: "input-foreground"
          background: "input-background"
          border: { width: 1, color: "input-border" }
          border-radius: 4
          line-height: 1.4
          resize: none
        on-focus:
          border-color: "focusBorder"
        on-keydown:
          Enter: "sendMessage"  # Shift+Enter for newline
          Shift+Enter: "newline"

      @element send-button
        type: button
        content: "Send"
        align-self: flex-end
        style:
          padding: { x: 14, y: 6 }
          font-size: 13
          color: "button-foreground"
          background: "button-background"
          border: none
          border-radius: 4
          white-space: nowrap
        on-hover:
          background: "button-hoverBackground"
        on-disabled:
          opacity: 0.5
          cursor: not-allowed
        on-click: "sendMessage"
        disabled: "isStreaming || input.length === 0"

  # ==========================================================================
  # VIEW 2: AUDIT LOG
  # ==========================================================================

  @view audit-view
    id: "dantecode.auditView"
    title: "Audit Log"
    layout: column
    fill: parent
    retain: true

    # ---- Zone: Audit Header ----
    @zone audit-header
      layout: row
      align: center
      justify: space-between
      padding: { x: 12, y: 8 }
      border: { bottom: 1, color: "panel-border" }
      background: "sideBarSectionHeader-background"
      shrink: 0

      @element audit-title
        type: text
        content: "Audit Log"
        style:
          font-weight: 600
          font-size: 13
          color: "sideBarSectionHeader-foreground"

      @element refresh-btn
        type: icon-button
        icon: "refresh"
        tooltip: "Refresh audit log"
        on-click: "refreshAuditLog"

    # ---- Zone: Filter Bar ----
    @zone audit-filter
      layout: row
      align: center
      gap: 6
      padding: { x: 12, y: 6 }
      border: { bottom: 1, color: "panel-border" }
      shrink: 0

      @element filter-input
        type: text-input
        placeholder: "Filter events..."
        flex: 1
        style:
          padding: { x: 8, y: 4 }
          font-size: 12
          color: "input-foreground"
          background: "input-background"
          border: { width: 1, color: "input-border" }
          border-radius: 2

      @element event-count
        type: text
        content: "{filteredCount}/{totalCount}"
        style:
          font-size: 11
          color: "descriptionForeground"
          white-space: nowrap

    # ---- Zone: Event List ----
    @zone audit-events
      layout: column
      flex: 1
      overflow-y: auto
      gap: 0

      @element audit-event
        type: list-item
        repeat: "auditEvents"
        layout: row
        align: center
        gap: 8
        padding: { x: 12, y: 6 }
        border: { bottom: 1, color: "panel-border" }
        cursor: pointer

        @element event-icon
          type: codicon
          icon: "{event.icon}"  # Maps to EVENT_TYPE_ICONS
          style:
            font-size: 14
            color: "descriptionForeground"
            flex-shrink: 0

        @element event-details
          type: container
          flex: 1
          layout: column
          gap: 2
          overflow: hidden

          @element event-label
            type: text
            content: "{event.label}"  # Maps to EVENT_TYPE_LABELS
            style:
              font-size: 12
              font-weight: 500
              color: "foreground"
              overflow: ellipsis
              white-space: nowrap

          @element event-payload
            type: text
            content: "{event.summary}"
            style:
              font-size: 11
              color: "descriptionForeground"
              overflow: ellipsis
              white-space: nowrap

        @element event-time
          type: text
          content: "{event.relativeTime}"  # e.g., "2m ago"
          style:
            font-size: 10
            color: "descriptionForeground"
            white-space: nowrap
            flex-shrink: 0

      @element empty-state
        type: card
        visibility: "auditEvents.length === 0"
        layout: column
        align: center
        justify: center
        padding: { x: 16, y: 32 }
        gap: 8

        @element empty-icon
          type: codicon
          icon: "notebook"
          style:
            font-size: 32
            color: "descriptionForeground"
            opacity: 0.5

        @element empty-text
          type: text
          content: "No audit events yet"
          style:
            font-size: 12
            color: "descriptionForeground"

# ============================================================================
# STATUS BAR
# ============================================================================

@zone status-bar
  position: { slot: "statusBar", alignment: "left", priority: 100 }
  layout: row
  align: center
  gap: 4

  @element gate-icon
    type: codicon
    variants:
      passed: { icon: "pass-filled", color: "statusBarItem.foreground" }
      failed: { icon: "error", background: "statusBarItem.errorBackground", color: "statusBarItem.errorForeground" }
      pending: { icon: "loading~spin", background: "statusBarItem.warningBackground", color: "statusBarItem.warningForeground" }
      none: { icon: "dash" }

  @element status-label
    type: text
    content: "DanteCode: {modelShortName}"

  @element sandbox-icon
    type: codicon
    icon: "vm"
    visibility: "sandboxEnabled"

  on-click: "dantecode.switchModel"
  tooltip: |
    Model: {currentModel}
    PDSE gate: {gateStatus}
    Sandbox: {sandboxEnabled ? 'enabled' : 'disabled'}

    Click to switch model

# ============================================================================
# INTERACTION MAP
# ============================================================================

@interactions
  # Chat flow
  sendMessage:
    trigger: "send-button.click OR textarea.Enter"
    guard: "!isStreaming && input.length > 0"
    sequence:
      1: hide(welcome)
      2: appendMessage("user", input.text)
      3: clearInput()
      4: setStreaming(true)
      5: show(typing-indicator)
      6: createAssistantBubble()
      7: postMessage("chat_request", { text })

  receiveChunk:
    trigger: "message:chat_response_chunk"
    action: updateAssistantBubble(payload.partial)

  receiveDone:
    trigger: "message:chat_response_done"
    sequence:
      1: finalizeAssistantBubble(payload.text)
      2: setStreaming(false)
      3: hide(typing-indicator)

  receiveScore:
    trigger: "message:pdse_score"
    action: updatePDSEBadge(payload.overall, payload.passedGate)

  # Model switching
  modelChange:
    trigger: "model-select.change"
    action: postMessage("model_change", { model: select.value })

  # Context file management
  fileAdd:
    trigger: "command:dantecode.addFileToContext"
    action: postMessage("file_add", { filePath })

  fileRemove:
    trigger: "context-pill.remove-btn.click"
    action: postMessage("file_remove", { filePath })

  # Audit log
  refreshAuditLog:
    trigger: "refresh-btn.click"
    action: reloadAuditEvents()

# ============================================================================
# SPATIAL DIMENSIONS (px at default VS Code zoom)
# ============================================================================

@dimensions
  sidebar-width: { min: 200, default: 300, max: 600 }
  header-height: 36
  model-bar-height: 32
  context-bar-height: { min: 0, max: 80 }
  input-area-height: { min: 52, max: 148 }  # 36px textarea + 16px padding
  message-gap: 12
  pill-height: 22
  audit-event-height: 44
  status-bar-height: 22

# ============================================================================
# ACCESSIBILITY
# ============================================================================

@a11y
  keyboard:
    Tab: "Navigate between header, model-select, context-pills, messages, input"
    Enter: "Send message (in textarea)"
    Shift+Enter: "New line (in textarea)"
    Escape: "Cancel streaming / close dropdown"
  aria:
    messages: { role: "log", aria-live: "polite", aria-label: "Chat messages" }
    input: { role: "textbox", aria-label: "Message input" }
    model-select: { role: "listbox", aria-label: "Model selector" }
    pdse-badge: { role: "status", aria-label: "PDSE quality score" }
    audit-events: { role: "list", aria-label: "Audit event log" }
  contrast:
    minimum: "4.5:1"
    note: "Inherited from VS Code theme, which enforces WCAG AA"
