# ============================================================================
# DanteCode Environment Variables
# Copy to .env and fill in your values
# ============================================================================

# ── AI Provider API Keys ────────────────────────────────────────────────────
# At least one is required (Anthropic recommended)

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-api03-...

# X.AI (Grok)
XAI_API_KEY=xai-...
# GROK_API_KEY=xai-...  # Alternative variable name

# OpenAI (GPT)
OPENAI_API_KEY=sk-proj-...

# Google (Gemini)
GOOGLE_API_KEY=...
# GEMINI_API_KEY=...    # Alternative variable name

# Groq
GROQ_API_KEY=gsk_...

# Ollama (local, no key needed)
# OLLAMA_BASE_URL=http://localhost:11434

# ── GitHub Integration ──────────────────────────────────────────────────────
# Required for /review, /triage, and GitHub automation features

GITHUB_TOKEN=ghp_...
# GH_TOKEN=ghp_...      # Alternative variable name

# GitHub webhook secret (for automation triggers)
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ── DanteCode Configuration ─────────────────────────────────────────────────

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# API authentication token for HTTP server
DANTECODE_API_TOKEN=your-secret-token

# Project workspace root (for Docker)
PROJECT_ROOT=./workspace

# ── Model Adaptation ────────────────────────────────────────────────────────
# Mode: observe-only | staged | auto
DANTE_MODEL_ADAPTATION_MODE=observe-only

# Disable model adaptation entirely (1 = disabled)
DANTE_DISABLE_MODEL_ADAPTATION=0

# ── Advanced Configuration ──────────────────────────────────────────────────

# Enable debug logging (1 = enabled)
DANTECODE_DEBUG=0

# Export telemetry data (1 = enabled)
DANTECODE_EXPORT_TELEMETRY=0

# Node environment (development | production)
NODE_ENV=production

# ── Slack Integration (optional) ────────────────────────────────────────────
# SLACK_SIGNING_SECRET=your-slack-secret

# ── GitLab Integration (optional) ───────────────────────────────────────────
# GITLAB_WEBHOOK_SECRET=your-gitlab-secret

# ── Custom Webhooks (optional) ──────────────────────────────────────────────
# CUSTOM_WEBHOOK_SECRET=your-custom-secret
