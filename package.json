{
  "name": "dantecode",
  "version": "0.9.2",
  "private": true,
  "type": "module",
  "description": "Portable, model-agnostic skill runtime and coding agent with DanteForge verification",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantericardo88/dantecode.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "clean": "turbo run clean",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\"",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "release:doctor": "node scripts/release-doctor.mjs",
    "release:matrix": "node scripts/release-matrix.mjs",
    "smoke:cli": "node scripts/smoke-cli.mjs",
    "smoke:install": "node scripts/smoke-install.mjs",
    "smoke:skill-import": "node scripts/smoke-skill-import.mjs",
    "smoke:provider": "node scripts/smoke-provider.mjs",
    "smoke:external": "node scripts/smoke-external.mjs",
    "publish:dry-run": "node scripts/publish-dry-run.mjs",
    "measure:scores": "node scripts/measure-scores.mjs",
    "bench:build": "node scripts/bench-build-speed.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:check:full": "npm run build && npm run typecheck && npm run lint && npm run format:check && npm test && npm run test:coverage && npm run release:quickstart-proof && npm run smoke:external && npm run publish:dry-run",
    "release:check:strict": "npm run release:check:full",
    "release:gate": "node scripts/release-check.mjs",
    "release:gate:windows-smoke": "node scripts/release/run-external-gate.mjs windowsSmoke",
    "release:gate:live-provider": "node scripts/release/run-external-gate.mjs liveProvider",
    "release:gate:live-provider:dry": "node scripts/release/run-external-gate.mjs liveProvider --dry",
    "release:gate:publish-dry-run": "node scripts/release/run-external-gate.mjs publishDryRun",
    "release:gate:quickstart": "node scripts/release/verify-quickstart.mjs",
    "release:prove-quickstart": "node scripts/release/verify-quickstart.mjs",
    "release:quickstart-proof": "npm run release:prove-quickstart",
    "release:generate": "node scripts/release/generate-readiness.mjs",
    "release:sync": "node scripts/release/sync-readiness.mjs",
    "release:assert": "node scripts/release/assert-readiness.mjs",
    "generate:samples": "node scripts/generate-verification-samples.mjs",
    "check:anti-stub": "node scripts/anti-stub-scan.mjs",
    "check:stubs": "node scripts/anti-stub-scan.mjs",
    "benchmark:swe": "cd benchmarks/swe-bench && python swe_bench_runner.py",
    "benchmark:providers": "cd benchmarks/providers && node smoke-test.mjs --all",
    "benchmark:provider": "cd benchmarks/providers && node smoke-test.mjs",
    "benchmark:speed": "cd benchmarks/speed && node speed-benchmark.mjs",
    "benchmark:all": "npm run benchmark:providers && npm run benchmark:speed",
    "check:cli-smoke": "node scripts/cli-smoke.mjs",
    "cli": "node packages/cli/dist/index.js",
    "dantecode": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.3",
    "prettier": "^3.4.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.17",
    "typedoc": "^0.28.18",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@octokit/core": "^7.0.6",
    "glob": "^13.0.6"
  }
}
