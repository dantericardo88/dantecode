{
  "name": "dantecode",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Portable, model-agnostic skill runtime and coding agent with DanteForge verification",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantericardo88/dantecode.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\"",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "release:doctor": "node scripts/release-doctor.mjs",
    "release:matrix": "node scripts/release-matrix.mjs",
    "smoke:cli": "node scripts/smoke-cli.mjs",
    "smoke:install": "node scripts/smoke-install.mjs",
    "smoke:skill-import": "node scripts/smoke-skill-import.mjs",
    "smoke:provider": "node scripts/smoke-provider.mjs",
    "publish:dry-run": "node scripts/publish-dry-run.mjs",
    "release:check": "npm run build && npm run typecheck && npm run lint && npm run format:check && npm test && npm run test:coverage && npm run smoke:cli && npm run smoke:install && npm run smoke:skill-import && npm run publish:dry-run",
    "release:check:strict": "npm run release:check",
    "cli": "node packages/cli/dist/index.js",
    "dantecode": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.3",
    "prettier": "^3.4.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.17",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@octokit/core": "^7.0.6"
  }
}
