{
  "name": "@dantecode/desktop",
  "version": "1.0.0",
  "description": "DanteCode desktop application — Electron wrapper for the AI coding agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantericardo88/dantecode.git",
    "directory": "packages/desktop"
  },
  "keywords": [
    "dantecode",
    "desktop",
    "electron",
    "ai",
    "coding-agent"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "main": "dist/main.cjs",
  "scripts": {
    "build": "tsup src/main.ts --format cjs --dts",
    "dev": "electron .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --config ../../vitest.package.config.ts",
    "clean": "rm -rf dist",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@dantecode/config-types": "1.0.0",
    "@dantecode/core": "1.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "dev.dantecode.desktop",
    "productName": "DanteCode",
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
