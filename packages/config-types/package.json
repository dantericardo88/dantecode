{
  "name": "@dantecode/config-types",
  "version": "1.0.0",
  "description": "Shared TypeScript type definitions for DanteCode configuration",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantecode/dantecode.git",
    "directory": "packages/config-types"
  },
  "keywords": [
    "dantecode",
    "config",
    "types",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "echo 'no tests for types package'",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
