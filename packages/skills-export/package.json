{
  "name": "@dantecode/skills-export",
  "version": "0.9.2",
  "description": "DanteCode skill exporter — export to Agent Skills format and Codex-compatible layouts",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": { ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" } },
  "scripts": {
    "build": "node -e \"['index.d.ts','index.d.ts.map'].forEach(f=>{try{require('fs').unlinkSync('dist/'+f)}catch{}})\" && tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../vitest.package.config.ts"
  },
  "files": ["dist"],
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantericardo88/dantecode.git",
    "directory": "packages/skills-export"
  }
}
