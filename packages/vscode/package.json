{
  "name": "dantecode",
  "displayName": "DanteCode",
  "description": "Preview VS Code client for the DanteCode portable skill runtime and coding agent",
  "version": "0.9.2",
  "publisher": "dantecode",
  "license": "MIT",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "badges": [],
  "preview": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantericardo88/dantecode.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "coding",
    "agent",
    "grok",
    "model-agnostic",
    "copilot",
    "code-review",
    "quality",
    "danteforge"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --config ../../vitest.package.config.ts --exclude='**/vscode.test.ts'",
    "test:integration": "vitest run --config ../../vitest.package.config.ts src/vscode.test.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "package": "npx --yes @vscode/vsce package"
  },
  "dependencies": {
    "@dantecode/config-types": "0.9.2",
    "@dantecode/core": "0.9.2",
    "@dantecode/danteforge": "0.9.2",
    "@dantecode/git-engine": "0.9.2",
    "@dantecode/skill-adapter": "0.9.2",
    "@dantecode/ux-polish": "0.9.2"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
