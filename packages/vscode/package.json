{
  "name": "dantecode",
  "displayName": "DanteCode",
  "description": "Preview VS Code client for the DanteCode portable skill runtime and coding agent",
  "version": "1.0.0",
  "publisher": "dantecode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantericardo88/dantecode.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "coding",
    "agent",
    "grok",
    "model-agnostic",
    "copilot",
    "code-review",
    "quality",
    "danteforge"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --config ../../vitest.package.config.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "package": "vsce package"
  },
  "dependencies": {
    "@dantecode/config-types": "1.0.0",
    "@dantecode/core": "1.0.0",
    "@dantecode/danteforge": "1.0.0",
    "@dantecode/git-engine": "1.0.0",
    "@dantecode/skill-adapter": "1.0.0",
    "@dantecode/ux-polish": "1.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dantecode",
          "title": "DanteCode",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "dantecode": [
        {
          "type": "webview",
          "id": "dantecode.chatView",
          "name": "Chat"
        },
        {
          "type": "webview",
          "id": "dantecode.auditView",
          "name": "Audit Log"
        },
        {
          "type": "webview",
          "id": "dantecode.automationView",
          "name": "Automation"
        },
        {
          "type": "webview",
          "id": "dantecode.verificationView",
          "name": "Verification"
        },
        {
          "id": "dantecode.repoMap",
          "name": "Repo Map",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "dantecode.selfUpdate",
        "title": "DanteCode: Self Update",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.openChat",
        "title": "DanteCode: Open Chat",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.addFileToContext",
        "title": "DanteCode: Add File to Context",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.importClaudeSkills",
        "title": "DanteCode: Import Claude Skills",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.runPDSE",
        "title": "DanteCode: Run PDSE Score on File",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.runGStack",
        "title": "DanteCode: Run GStack QA",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.switchModel",
        "title": "DanteCode: Switch Model",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.toggleSandbox",
        "title": "DanteCode: Toggle Sandbox Mode",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.showLessons",
        "title": "DanteCode: Show Project Lessons",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.initProject",
        "title": "DanteCode: Initialize Project",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.acceptDiff",
        "title": "DanteCode: Accept Diff Hunk",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.rejectDiff",
        "title": "DanteCode: Reject Diff Hunk",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.reviewDiff",
        "title": "DanteCode: Review Pending Diff",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.acceptDiffHunks",
        "title": "DanteCode: Accept Selected Diff Hunks",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.rejectDiffHunks",
        "title": "DanteCode: Reject Selected Diff Hunks",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.createCheckpoint",
        "title": "DanteCode: Create Checkpoint",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.listCheckpoints",
        "title": "DanteCode: List Checkpoints",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.rewindCheckpoint",
        "title": "DanteCode: Rewind Checkpoint",
        "category": "DanteCode"
      },
      {
        "command": "dantecode.setupApiKeys",
        "title": "DanteCode: Setup API Keys",
        "category": "DanteCode"
      }
    ],
    "keybindings": [
      {
        "command": "dantecode.openChat",
        "key": "ctrl+alt+d",
        "mac": "cmd+alt+d"
      },
      {
        "command": "dantecode.addFileToContext",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorFocus"
      },
      {
        "command": "dantecode.switchModel",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      },
      {
        "command": "dantecode.runPDSE",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p"
      },
      {
        "command": "dantecode.toggleSandbox",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "focusedView == 'dantecode.chatView'"
      }
    ],
    "configuration": {
      "title": "DanteCode",
      "properties": {
        "dantecode.defaultModel": {
          "type": "string",
          "default": "grok/grok-3",
          "description": "Default model for DanteCode. Format: provider/model-id"
        },
        "dantecode.fimModel": {
          "type": "string",
          "default": "",
          "description": "Optional dedicated inline-completion model. Format: provider/model-id"
        },
        "dantecode.pdseThreshold": {
          "type": "number",
          "default": 85,
          "minimum": 0,
          "maximum": 100,
          "description": "Minimum PDSE score to pass quality gate"
        },
        "dantecode.autoCommit": {
          "type": "boolean",
          "default": true,
          "description": "Automatically commit accepted edits"
        },
        "dantecode.sandboxEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Run bash commands in Docker sandbox"
        },
        "dantecode.multilineCompletions": {
          "type": "string",
          "enum": ["auto", "always", "never"],
          "default": "auto",
          "description": "Control multi-line inline completions. 'auto' detects context, 'always' forces multi-line, 'never' forces single-line."
        },
        "dantecode.debounceAdaptive": {
          "type": "boolean",
          "default": true,
          "description": "Automatically reduce completion debounce when typing quickly (>3 chars/sec)"
        },
        "dantecode.inline.debounceMs": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 2000,
          "description": "Custom debounce delay (ms) for inline completions. 0 = use provider-aware defaults (Ollama 100ms, Grok 150ms, others 180ms)."
        },
        "dantecode.inline.multiline": {
          "type": "string",
          "enum": ["auto", "always", "never"],
          "default": "auto",
          "description": "Control multiline inline completions. 'auto' detects block context (braces, arrows), 'always' forces multiline, 'never' forces single-line."
        },
        "dantecode.inline.pdseWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Show PDSE quality warnings as ghost-text comments and Problems panel entries when inline completion scores below threshold."
        }
      }
    },
    "menus": {
      "explorer/context": [
        {
          "command": "dantecode.addFileToContext",
          "group": "dantecode@1"
        }
      ],
      "editor/context": [
        {
          "command": "dantecode.addFileToContext",
          "group": "dantecode",
          "when": "editorFocus"
        },
        {
          "command": "dantecode.runPDSE",
          "group": "dantecode",
          "when": "editorFocus"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "dantecode.welcome",
        "title": "Get Started with DanteCode",
        "description": "Set up your AI coding assistant in minutes",
        "steps": [
          {
            "id": "setupApiKey",
            "title": "Configure API Keys",
            "description": "Set up your preferred LLM provider (Grok, Claude, GPT, Ollama, etc.)",
            "media": {
              "markdown": "## Quick Setup\n\nRun the command **DanteCode: Setup API Keys** to configure your providers.\n\nDanteCode supports 7+ providers — use any model you prefer."
            },
            "completionEvents": ["onCommand:dantecode.setupApiKeys"]
          },
          {
            "id": "openChat",
            "title": "Start a Chat",
            "description": "Open the DanteCode sidebar and ask your first question",
            "media": {
              "markdown": "## Chat with DanteCode\n\nClick the DanteCode icon in the activity bar, or press **Ctrl+Alt+D**.\n\nAsk anything: 'Fix the bug in auth.ts', 'Add unit tests', 'Refactor this function'."
            },
            "completionEvents": ["onCommand:dantecode.openChat"]
          },
          {
            "id": "tryPDSE",
            "title": "Run Quality Check",
            "description": "Score your code with DanteForge's PDSE verification",
            "media": {
              "markdown": "## Quality Gates\n\nDanteCode includes built-in quality verification:\n- **PDSE Score**: Production-Deployment Safety Evaluation\n- **Anti-Stub Detection**: Catches placeholder code\n- **Constitution Check**: Enforces coding standards"
            },
            "completionEvents": ["onCommand:dantecode.runPDSE"]
          },
          {
            "id": "learnMore",
            "title": "Explore Features",
            "description": "Discover background agents, semantic search, and more",
            "media": {
              "markdown": "## Power Features\n\n- **Background Agents**: `/bg` runs tasks in parallel\n- **Semantic Search**: `/search` finds code by meaning\n- **Event Gateway**: `/listen` receives webhooks\n- **Memory**: `/remember` saves project knowledge\n- **Model Switching**: `/model` changes LLM on the fly"
            }
          }
        ]
      }
    ]
  }
}
