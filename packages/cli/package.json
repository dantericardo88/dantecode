{
  "name": "@dantecode/cli",
  "version": "1.0.0",
  "description": "DanteCode CLI - portable skill runtime and coding agent with DanteForge verification",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantericardo88/dantecode.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "dantecode",
    "cli",
    "ai",
    "coding-agent",
    "terminal"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "bin": {
    "dantecode": "dist/index.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --config ../../vitest.package.config.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "ai": "^4.0.0",
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@octokit/rest": "^20.1.2",
    "cheerio": "^1.0.0",
    "dockerode": "^4.0.0",
    "node-fetch": "^3.3.0",
    "sql.js": "^1.11.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@dantecode/config-types": "1.0.0",
    "@dantecode/core": "1.0.0",
    "@dantecode/dante-gaslight": "1.0.0",
    "@dantecode/dante-sandbox": "1.0.0",
    "@dantecode/dante-skillbook": "1.0.0",
    "@dantecode/danteforge": "1.0.0",
    "@dantecode/debug-trail": "1.0.0",
    "@dantecode/evidence-chain": "1.0.0",
    "@dantecode/git-engine": "1.0.0",
    "@dantecode/memory-engine": "1.0.0",
    "@dantecode/runtime-spine": "1.0.0",
    "@dantecode/sandbox": "1.0.0",
    "@dantecode/skill-adapter": "1.0.0",
    "@dantecode/ux-polish": "1.0.0",
    "@dantecode/web-extractor": "1.0.0",
    "@dantecode/web-research": "1.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
