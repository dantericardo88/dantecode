{
  "name": "@dantecode/cli",
  "version": "1.0.0",
  "description": "DanteCode CLI — interactive AI coding agent with model routing and DanteForge quality gates",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dantecode/dantecode.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "dantecode",
    "cli",
    "ai",
    "coding-agent",
    "terminal"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "bin": {
    "dantecode": "./dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dantecode/config-types": "*",
    "@dantecode/core": "*",
    "@dantecode/danteforge": "*",
    "@dantecode/git-engine": "*",
    "@dantecode/skill-adapter": "*",
    "yaml": "^2.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
