{
  "name": "@dantecode/codebase-index",
  "version": "1.0.0",
  "description": "Codebase indexing: multi-language symbol extraction, repo map, symbol definition lookup, RRF fusion, context assembly",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantericardo88/dantecode.git",
    "directory": "packages/codebase-index"
  },
  "keywords": ["dantecode", "codebase-index", "repo-map", "bm25", "symbol-extraction"],
  "engines": { "node": ">=18" },
  "files": ["dist"],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --config ../../vitest.package.config.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "publishConfig": { "access": "public" },
  "dependencies": {
    "@dantecode/core": "1.0.0",
    "minisearch": "^7.1.1"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "tree-sitter": "^0.21.0",
    "tree-sitter-typescript": "^0.21.0",
    "tree-sitter-javascript": "^0.21.0",
    "tree-sitter-python": "^0.21.0"
  }
}
