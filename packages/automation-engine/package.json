{
  "name": "@dantecode/automation-engine",
  "version": "0.9.2",
  "description": "High-level automation orchestration for DanteCode - git workflows, auto-PR, event-driven tasks",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "node -e \"['index.d.ts','index.d.ts.map'].forEach(f=>{try{require('fs').unlinkSync('dist/'+f)}catch{}})\" && tsup src/index.ts --format esm && node scripts/generate-stub-dts.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../vitest.package.config.ts"
  },
  "dependencies": {
    "@dantecode/config-types": "0.9.2",
    "@dantecode/core": "0.9.2",
    "@dantecode/git-engine": "0.9.2",
    "@dantecode/danteforge": "0.9.2",
    "@dantecode/runtime-spine": "0.9.2"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantericardo88/dantecode.git",
    "directory": "packages/automation-engine"
  }
}
