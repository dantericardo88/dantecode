{
  "name": "@dantecode/skill-adapter",
  "version": "1.0.0",
  "description": "Skill adapter for importing and wrapping external AI coding agent skills",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantecode/dantecode.git",
    "directory": "packages/skill-adapter"
  },
  "keywords": [
    "dantecode",
    "skills",
    "adapter",
    "ai-agent",
    "interop"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --config ../../vitest.package.config.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dantecode/config-types": "1.0.0",
    "@dantecode/core": "1.0.0",
    "@dantecode/danteforge": "1.0.0",
    "yaml": "^2.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
