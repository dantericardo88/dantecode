{
  "name": "@dantecode/debug-trail",
  "version": "0.9.1",
  "description": "Always-on, immutable, queryable forensic debug spine for DanteCode agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantericardo88/dantecode.git",
    "directory": "packages/debug-trail"
  },
  "keywords": [
    "dantecode",
    "debug",
    "audit",
    "forensic",
    "trail",
    "snapshot",
    "replay"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "node -e \"['index.d.ts','index.d.ts.map'].forEach(f=>{try{require('fs').unlinkSync('dist/'+f)}catch{}})\" && tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --config ../../vitest.package.config.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@dantecode/config-types": "0.9.1",
    "@dantecode/core": "0.9.1",
    "@dantecode/evidence-chain": "0.9.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
