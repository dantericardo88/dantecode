{
  "name": "@dantecode/danteforge",
  "version": "1.0.0",
  "description": "DanteForge quality verification engine — PDSE scoring, anti-stub enforcement, constitution checker",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantericardo88/dantecode.git",
    "directory": "packages/danteforge"
  },
  "keywords": [
    "dantecode",
    "danteforge",
    "quality",
    "pdse",
    "anti-stub",
    "code-quality"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:dev": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --config ../../vitest.package.config.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@dantecode/config-types": "1.0.0",
    "@dantecode/core": "1.0.0",
    "sql.js": "^1.11.0",
    "zod": "^3.24.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "javascript-obfuscator": "^5.3.0",
    "terser": "^5.46.1",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
