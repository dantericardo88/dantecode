{
  "name": "@dantecode/workspace",
  "version": "0.1.0",
  "description": "Workspace abstraction for local/remote/container execution symmetry",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --config ../../vitest.package.config.ts",
    "test:watch": "vitest --config ../../vitest.package.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dantecode/runtime-spine": "*",
    "@dantecode/dante-sandbox": "*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
