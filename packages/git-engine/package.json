{
  "name": "@dantecode/git-engine",
  "version": "1.0.0",
  "description": "Git operations engine — commits, diffs, worktrees, and repo mapping for DanteCode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dantecode/dantecode.git",
    "directory": "packages/git-engine"
  },
  "keywords": [
    "dantecode",
    "git",
    "worktree",
    "diff",
    "commit"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dantecode/config-types": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
