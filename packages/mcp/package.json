{
  "name": "@dantecode/mcp",
  "version": "1.0.0",
  "description": "MCP protocol client and server for DanteCode — connect to external tools and expose DanteForge as MCP",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantericardo88/dantecode.git",
    "directory": "packages/mcp"
  },
  "keywords": [
    "dantecode",
    "mcp",
    "model-context-protocol",
    "tool-bridge"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --config ../../vitest.package.config.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@dantecode/config-types": "1.0.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
