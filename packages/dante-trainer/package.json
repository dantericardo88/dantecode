{
  "name": "@dantecode/dante-trainer",
  "version": "1.0.0",
  "description": "Training pipeline, eval metrics, and model integration for DanteCode next-edit prediction",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantericardo88/dantecode.git",
    "directory": "packages/dante-trainer"
  },
  "keywords": [
    "dantecode",
    "fine-tuning",
    "lora",
    "next-edit",
    "qwen",
    "unsloth"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --config ../../vitest.package.config.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
