{
  "name": "@dantecode/web-extractor",
  "version": "0.9.2",
  "description": "Production-grade, intelligent page analysis and extraction engine for DanteCode",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "node -e \"['index.d.ts','index.d.ts.map'].forEach(f=>{try{require('fs').unlinkSync('dist/'+f)}catch{}})\" && tsup && node scripts/generate-stub-dts.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../vitest.package.config.ts"
  },
  "dependencies": {
    "@dantecode/core": "0.9.2",
    "@dantecode/runtime-spine": "0.9.2",
    "ai": "^4.3.19",
    "crawlee": "^3.16.0",
    "electron": "41.1.1",
    "vite": "8.0.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantericardo88/dantecode.git",
    "directory": "packages/web-extractor"
  }
}
