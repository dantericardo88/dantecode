{
  "name": "@dantecode/core",
  "version": "1.0.0",
  "description": "Core model router, audit logging, and state management for DanteCode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dantecode/dantecode.git",
    "directory": "packages/core"
  },
  "keywords": [
    "dantecode",
    "ai",
    "model-router",
    "llm",
    "vercel-ai-sdk"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dantecode/config-types": "*",
    "ai": "^4.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/anthropic": "^1.0.0",
    "zod": "^3.24.0",
    "yaml": "^2.7.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
