{
  "name": "@dantecode/observability",
  "version": "0.9.2",
  "description": "Observability system - metrics, tracing, health checks",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --config ../../vitest.package.config.ts",
    "test:watch": "vitest --config ../../vitest.package.config.ts"
  },
  "keywords": [
    "observability",
    "metrics",
    "tracing",
    "health-checks"
  ],
  "author": "DanteCode Team",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/dantecode",
    "directory": "packages/observability"
  }
}
